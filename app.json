{
  "expo": {
    "name": "Orbit",
    "slug": "orbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "orbit",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#040407",
    "splash": {
      "backgroundColor": "#040407"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.orbitapp.orbit",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to authenticate with Face ID",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#040407"
      },
      "package": "io.orbitapp.orbit"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
